<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#020617</item>
        <item name="colorPrimaryDark">#000000</item>
        <item name="colorAccent">#00ff00</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">#020617</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">#020617</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#020617</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#020617</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        

        <item name="windowSplashScreenAnimationDuration">2000</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
</resources>
